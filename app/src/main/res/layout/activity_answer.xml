<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollTelaResposta"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robot_background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/layoutTelaResposta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <TextView
            android:id="@+id/txtTituloResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/answer_title"
            android:textColor="@color/robot_primary_dark"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgRoboResposta"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            android:contentDescription="@string/main_robot_image_description"
            android:src="@drawable/ic_robo_marciano" />

        <TextView
            android:id="@+id/txtIntroducaoResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/answer_intro"
            android:textColor="@color/robot_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtTipoRoboResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:textColor="@color/robot_primary_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtLabelMensagemUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/answer_user_message_label"
            android:textColor="@color/robot_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMensagemUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_response_card"
            android:minHeight="72dp"
            android:padding="16dp"
            android:textColor="@color/robot_text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtLabelResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/answer_robot_message_label"
            android:textColor="@color/robot_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtRespostaRobo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_response_card"
            android:elevation="2dp"
            android:minHeight="110dp"
            android:padding="16dp"
            android:textColor="@color/robot_primary_dark"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/button_back"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>