<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollTelaPrincipal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/layoutTelaPrincipal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/main_title"
            android:textColor="#1B2A41"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSubtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/main_subtitle"
            android:textColor="#5C677D"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/imgRobo"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="28dp"
            android:contentDescription="@string/main_robot_image_description"
            android:src="@drawable/ic_robo_marciano" />

        <TextView
            android:id="@+id/txtTipoRobo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/label_robot_type"
            android:textColor="#1B2A41"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerTipoRobo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#2D6CDF"
            android:padding="8dp" />

        <TextView
            android:id="@+id/txtMensagem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/label_message"
            android:textColor="#1B2A41"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editMensagem"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#2D6CDF"
            android:gravity="top"
            android:hint="@string/hint_message"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:maxLines="5"
            android:padding="12dp"
            android:textColor="#1B2A41"
            android:textColorHint="#8D99AE"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="@string/button_send_message"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>